{
    "trading_mode": "spot",
    "margin_mode": "",
    "max_open_trades": 3,
    "stake_currency": "USD",
    "stake_amount": 500,
    "tradable_balance_ratio": 0.99,
    "fiat_display_currency": "USD",
    "dry_run": false,
    "dry_run_wallet": 10000,
    "cancel_open_orders_on_exit": false,
    "dataformat_ohlcv": "parquet",
    "dataformat_trades": "parquet",
    "asset_type": "stocks",
    "stock_symbols": ["AAPL", "MSFT", "TSLA", "NVDA"],
    "exchange": {
        "name": "interactivebrokers",
        "key": "",
        "secret": "",
        "skip_pair_validation": true,
        "ccxt_sync_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
            "AAPL/USD",
            "MSFT/USD",
            "TSLA/USD",
            "NVDA/USD"
        ],
        "pair_blacklist": []
    },
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": false,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": false,
        "order_book_top": 1
    },
    "order_types": {
        "entry": "limit",
        "exit": "limit",
        "stoploss": "market",
        "stoploss_on_exchange": false
    },
    "pairlists": [
        {
            "method": "StaticPairList",
            "allow_inactive": true
        }
    ],
    "api_server": {
        "enabled": true,
        "listen_ip_address": "0.0.0.0",
        "listen_port": 8080,
        "verbosity": "error",
        "enable_openapi": false,
        "jwt_secret_key": "changeme_generate_a_random_string_here",
        "CORS_origins": [],
        "username": "freqtrader",
        "password": "freqtrader"
    },
    "bot_name": "freqtrade-imt-stocks",
    "initial_state": "running",
    "force_entry_enable": false,
    "internals": {
        "process_throttle_secs": 5
    },
    "timeframe": "1h",
    "ib_host": "host.docker.internal",
    "ib_paper_port": 7497,
    "ib_live_port": 7497,
    "ib_client_id": 2
}
