# Environment variables for Algo Trading Academy
# Copy this file to .env and fill in your values
# This file is NOT needed for local dry-run with TWS (Stage 1-2)

# === Stage 3: VPS ===
# FREQTRADE__API_SERVER__PASSWORD=your_strong_password_here
# FREQTRADE__API_SERVER__JWT_SECRET_KEY=generate_random_string

# === Stage 4: Live Trading ===
# FREQTRADE__EXCHANGE__KEY=your_binance_api_key
# FREQTRADE__EXCHANGE__SECRET=your_binance_api_secret

# === Telegram (Stage 3+) ===
# FREQTRADE__TELEGRAM__TOKEN=your_telegram_bot_token
# FREQTRADE__TELEGRAM__CHAT_ID=your_chat_id

# === IB Gateway (VPS only — not needed for local TWS) ===
# Used only when deploying Freqtrade on a remote VPS without TWS installed.
# For local use: install TWS and enable API on port 7497 instead.
# TWS_USERID=your_ib_username
# TWS_PASSWORD=your_ib_password
# TRADING_MODE=paper