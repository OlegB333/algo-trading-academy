# Algo Trading Academy

# Secrets (NEVER commit)
.env

# Freqtrade runtime files
user_data/logs/*
!user_data/logs/.gitkeep
user_data/backtest_results/*
!user_data/backtest_results/.gitkeep
user_data/tradesv3.sqlite
user_data/tradesv3.dryrun.sqlite
user_data/tradesv3.sqlite-shm
user_data/tradesv3.sqlite-wal
user_data/config/config.override.json

# Downloaded data (too large for git)
user_data/data/*/*.parquet
user_data/data/*/*.json
user_data/data/*/*.json.gz
user_data/data/*/*.feather
user_data/data/*/futures/

# Keep standard BTC and ETH pairs for testing
!user_data/data/*/*btc*
!user_data/data/*/*BTC*
!user_data/data/*/*eth*
!user_data/data/*/*ETH*

# Python
__pycache__/
*.py[cod]
*.egg-info/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
